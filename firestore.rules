rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: leaderboard
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, 1-50 chars) - Player's name
    //   - score: number (required, positive) - Survival time in seconds
    //   - timestamp: timestamp (required) - When the score was achieved
    //   - uid: string (required) - User's unique ID
    //
    // Collection: users
    // Document ID: user ID
    // Fields:
    //   - name: string (optional)
    //   - email: string (optional)
    //   - role: string
    //   - badges: array
    //   - completedLevels: array
    //   - unlockedLevels: number
    //   - levelStars: map
    //   - redDestroyed: number
    //   - highestScore: number (optional)
    //
    // Collection: levels
    // Document ID: custom level ID
    // Fields:
    //   - id: string (required)
    //   - name: string (required, 1-50 chars)
    //   - creatorId: string (required)
    //   - creatorName: string (required, 1-50 chars)
    //   - rubyCount: number (required, >= 0)
    //   - emeraldCount: number (required, >= 0)
    //   - starCount: number (required, >= 0)
    //   - timeLimit: number (required, >= 10)
    //   - songUrl: string (optional)
    //   - backgroundUrl: string (optional)
    //   - spawnMode: string (optional, 'equal' or 'progressive')
    //   - plays: number (required, >= 0)
    //   - createdAt: number (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "hamza.uae7575@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidScore(data) {
      return hasRequiredFields(['name', 'score', 'timestamp', 'uid']) &&
             hasOnlyAllowedFields(['name', 'score', 'timestamp', 'uid']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 50 &&
             data.score is number && data.score >= 0 &&
             data.timestamp is timestamp &&
             data.uid == request.auth.uid;
    }

    function isValidLevel(data) {
      let hasRequired = hasRequiredFields(['id', 'name', 'creatorId', 'creatorName', 'rubyCount', 'emeraldCount', 'starCount', 'timeLimit', 'plays', 'createdAt']);
      let hasOnlyAllowed = hasOnlyAllowedFields(['id', 'name', 'creatorId', 'creatorName', 'rubyCount', 'emeraldCount', 'starCount', 'timeLimit', 'songUrl', 'backgroundUrl', 'spawnMode', 'plays', 'createdAt']);
      return hasRequired && hasOnlyAllowed &&
             data.id is string && data.id.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 50 &&
             data.creatorId == request.auth.uid &&
             data.creatorName is string && data.creatorName.size() > 0 && data.creatorName.size() <= 50 &&
             data.rubyCount is number && data.rubyCount >= 0 &&
             data.emeraldCount is number && data.emeraldCount >= 0 &&
             data.starCount is number && data.starCount >= 0 &&
             data.timeLimit is number && data.timeLimit >= 10 &&
             (!('songUrl' in data) || (data.songUrl is string && data.songUrl.size() <= 500)) &&
             (!('backgroundUrl' in data) || (data.backgroundUrl is string && data.backgroundUrl.size() <= 500)) &&
             (!('spawnMode' in data) || (data.spawnMode in ['equal', 'progressive'])) &&
             data.plays is number && data.plays >= 0 &&
             data.createdAt is number;
    }

    function isValidLevelUpdate(data, oldData) {
      // Allow creator to update everything, or others to only increment plays
      return (isAuthenticated() && request.auth.uid == oldData.creatorId && isValidLevel(data)) ||
             (data.diff(oldData).affectedKeys().hasOnly(['plays']) && data.plays == oldData.plays + 1);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /leaderboard/{scoreId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidScore(request.resource.data);
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && hasOnlyAllowedFields(['name', 'email', 'role', 'photoURL', 'badges', 'completedLevels', 'unlockedLevels', 'levelStars', 'redDestroyed', 'highestScore']) &&
                             request.resource.data.role == (resource == null ? 'client' : resource.data.role);
      allow delete: if isAdmin();
    }

    match /levels/{levelId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidLevel(request.resource.data);
      allow update: if isAuthenticated() && isValidLevelUpdate(request.resource.data, resource.data);
      allow delete: if isAdmin() || isOwner(resource.data.creatorId);
    }

    match /custom_scores/{scoreId} {
      allow read: if true;
      allow create: if isAuthenticated() && 
                    hasRequiredFields(['levelId', 'userId', 'userName', 'score', 'timestamp']) &&
                    request.resource.data.userId == request.auth.uid &&
                    request.resource.data.score is number &&
                    request.resource.data.timestamp is timestamp &&
                    (!('accuracy' in request.resource.data) || request.resource.data.accuracy is number) &&
                    (!('completionTime' in request.resource.data) || request.resource.data.completionTime is number);
      allow update, delete: if isAdmin();
    }
  }
}
