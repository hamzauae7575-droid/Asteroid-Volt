{
  "entities": {
    "Score": {
      "title": "Score",
      "description": "A leaderboard entry for Infinite Mode.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Player's name."
        },
        "score": {
          "type": "number",
          "description": "Survival time in seconds."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the score was achieved."
        },
        "uid": {
          "type": "string",
          "description": "User's unique ID."
        }
      },
      "required": ["name", "score", "timestamp", "uid"]
    },
    "UserProgress": {
      "title": "UserProgress",
      "description": "Stores user's badges and level progress.",
      "type": "object",
      "properties": {
        "badges": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of earned badge IDs."
        },
        "completedLevels": {
          "type": "array",
          "items": { "type": "number" },
          "description": "List of completed level numbers."
        },
        "highestScore": {
          "type": "number",
          "description": "Highest score in infinite mode."
        }
      }
    },
    "CustomLevel": {
      "title": "CustomLevel",
      "description": "A user-created custom level.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "creatorId": { "type": "string" },
        "creatorName": { "type": "string" },
        "rubyCount": { "type": "number" },
        "emeraldCount": { "type": "number" },
        "starCount": { "type": "number" },
        "timeLimit": { "type": "number" },
        "songUrl": { "type": "string" },
        "plays": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "name", "creatorId", "creatorName", "rubyCount", "emeraldCount", "starCount", "timeLimit", "plays", "createdAt"]
    }
  },
  "firestore": {
    "users": {
      "schema": "UserProgress",
      "description": "User-specific progress data."
    },
    "levels": {
      "schema": "CustomLevel",
      "description": "Collection of user-created custom levels."
    }
  }
}
